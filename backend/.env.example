# Backend env template. Copy to `.env` for local dev; set the same
# variables in your hosting platform (Railway / Render) for production.
# `src/lib/env.ts` is the source of truth — every key parsed there
# should also appear here.

# Postgres connection string. Local dev: docker-compose Postgres.
# Production: Neon serverless connection (pooled URL works fine).
# Required by Prisma (read directly from process.env, not via env.ts).
DATABASE_URL="postgresql://jopay:jopay@localhost:5432/jopay?schema=public"

# HTTP listener. On Railway leave PORT unset — the platform injects it.
# HOST=0.0.0.0 is required for the container to accept external traffic.
PORT=3001
HOST=0.0.0.0

# Comma-separated origin allow-list for CORS. Local dev: Next.js dev server.
# Production: the deployed Vercel URL. Wildcard is unsafe; list explicit origins.
CORS_ORIGIN="http://localhost:3000"

# Optional. Used by /docs (Swagger) to render the correct server URL when
# the BE is deployed behind a proxy. e.g. https://api.jopay-demo.up.railway.app
# PUBLIC_BASE_URL=

# Rate limiting. 100 req/min per IP is generous; tune down for prod.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

# Trust X-Forwarded-* headers for client IP extraction (rate-limit, logs).
# OFF by default to prevent header spoofing on direct-traffic deployments.
# Production behind Railway / Vercel / Render: set to `true` (single trusted hop).
# For multi-hop: comma-separated CIDR list (e.g. "10.0.0.0/8,loopback").
TRUST_PROXY=false

# Pino log level.
LOG_LEVEL=info
NODE_ENV=development
