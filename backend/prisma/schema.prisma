generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  ORG
  CAMPAIGN
  MERCHANDISE
}

model Item {
  id          String   @id @default(cuid())
  category    Category
  subCategory String
  title       String
  description String
  logoUrl     String
  createdAt   DateTime @default(now())

  amountRaised Int?
  amountGoal   Int?
  deadline     DateTime?

  price Int?
  stock Int?

  // Compound index serves the common filtered-list query (category +
  // optional subCategory, ordered by createdAt DESC) for cursor pagination.
  @@index([category, subCategory, createdAt(sort: Desc)])

  // ⚠️ DO NOT run `prisma migrate dev` without `--create-only` against this
  // schema. The substring-search indexes on title/description live OUTSIDE
  // this file as raw-SQL migrations (`add_pg_trgm_gin_search`) because
  // Prisma's schema DSL can't yet express GIN + gin_trgm_ops. Auto-generated
  // migrations will detect "drift" between schema (no indexes on
  // title/description) and DB (has GIN indexes) and try to DROP them —
  // silently undoing our search performance work.
  //
  // Use `make migrate` (which runs `--create-only`) and review the
  // generated SQL before applying. If the diff contains DROP INDEX for
  // any *_trgm_idx, edit it out before `prisma migrate deploy`.
}
