generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  ORG
  CAMPAIGN
  MERCHANDISE
}

model Item {
  id          String   @id @default(cuid())
  category    Category
  subCategory String
  title       String
  description String
  logoUrl     String
  createdAt   DateTime @default(now())

  amountRaised Int?
  amountGoal   Int?
  deadline     DateTime?

  price Int?
  stock Int?

  // Compound index serves the common filtered-list query (category +
  // optional subCategory, ordered by createdAt DESC) for cursor pagination.
  @@index([category, subCategory, createdAt(sort: Desc)])

  // Note: substring-search indexes on title/description live OUTSIDE this
  // schema as raw-SQL migrations because Prisma can't yet declare GIN +
  // gin_trgm_ops in the schema DSL. See migration `add_pg_trgm_gin_search`.
}
