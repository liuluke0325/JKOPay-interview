generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  ORG
  CAMPAIGN
  MERCHANDISE
}

model Item {
  id          String   @id @default(cuid())
  category    Category
  subCategory String
  title       String
  description String
  logoUrl     String
  createdAt   DateTime @default(now())

  amountRaised Int?
  amountGoal   Int?
  deadline     DateTime?

  price Int?
  stock Int?

  @@index([category, subCategory, createdAt(sort: Desc)])
  @@index([title])
}
