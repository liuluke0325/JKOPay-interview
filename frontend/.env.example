# Frontend env template. Copy to `.env.local` for local dev; set the
# same variables in Vercel project settings for production.

# Backend base URL. NEXT_PUBLIC_ prefix exposes it to the browser
# (the openapi-fetch client runs client-side). Default falls back to
# the local dev port when unset (see `src/lib/api.ts`).
# Local dev: http://localhost:3001
# Production: https://<your-railway-service>.up.railway.app
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
