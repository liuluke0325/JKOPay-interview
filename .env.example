# Copy this file to `.env` (and `.env.local` for FE if needed) and fill in
# real values. `.env*` is gitignored; `.env.example` is committed as the
# canonical contract — keep it in sync with what the app actually reads.

# ─── Backend (Fastify + Prisma) ─────────────────────────────────────
# Local dev: docker-compose Postgres (host 5433 → container 5432; see docker-compose.yml)
# Append `&connection_limit=N` to size the Prisma client pool. Default is
# `num_physical_cpus * 2 + 1`. Under high concurrency raise to ~20-50 and
# pair with PgBouncer (transaction mode) on the DB side. See docs/SCALING.md.
DATABASE_URL=postgresql://jopay:jopay@localhost:5433/jopay?schema=public&connection_limit=10

# Production (Neon): set in Railway dashboard, NOT here.
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&connection_limit=20

# Fastify port (default 3001 to avoid colliding with Next.js on 3000)
PORT=3001

# Optional: tune CORS for local FE dev
CORS_ORIGIN=http://localhost:3000

# Public base URL embedded in the OpenAPI spec's `servers` block. Set this in
# Railway (or wherever the BE is hosted) so hosted Swagger UI doesn't advertise
# localhost. If unset, defaults to http://localhost:${PORT}.
# PUBLIC_BASE_URL=https://api.example.com

# Per-IP rate limit (requests / window). Defaults: 100 / 1 minute.
# Override per-environment; use lower limits in prod, higher in CI/load-test.
# Window accepts strings @fastify/rate-limit understands ("1 minute", "10s").
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=1 minute

# ─── Frontend (Next.js) ─────────────────────────────────────────────
# Public — exposed to the browser. Points at the BE.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Default locale for next-intl. Currently zh-TW only; en is a stub.
NEXT_PUBLIC_DEFAULT_LOCALE=zh-TW
